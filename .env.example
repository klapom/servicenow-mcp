# servicenow-mcp — environment config
# Copy to .env and fill in. .env is gitignored.

# Ports (override default, match PORT_REGISTRY.md)
LISTEN_PORT=32310
MCP_PORT=33310

# Logging
LOG_LEVEL=info

# vLLM (OpenAI-compatible)
VLLM_BASE_URL=http://localhost:32000/v1
VLLM_MODEL=qwen36-35b

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sn_mcp_docs

# Neo4j (knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aegis-rag-neo4j-password

# RAG retrieval
RETRIEVAL_TOP_K=8

# Docs directory (for lookup_table file reads; absolute or relative to WorkingDirectory)
SN_DOCS_DIR=docs

# Central embedding proxy (BGE-M3)
EMBED_BASE_URL=http://127.0.0.1:8097/v1
